<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ludoelite.controller.LoginController"
            styleClass="auth-root"
            prefWidth="500" prefHeight="620">

    <center>
        <VBox alignment="CENTER" spacing="0" styleClass="auth-card">
            <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

            <!-- Logo / Title -->
            <VBox alignment="CENTER" spacing="6">
                <Text styleClass="app-title" text="🎲 Ludo Elite"/>
                <Text styleClass="app-subtitle" text="Game Management Platform"/>
            </VBox>

            <Region prefHeight="32"/>

            <!-- Card header -->
            <Label text="Sign In" styleClass="form-title"/>
            <Label text="Enter your credentials to continue" styleClass="form-subtitle"/>

            <Region prefHeight="24"/>

            <!-- Error label -->
            <Label fx:id="errorLabel" styleClass="error-label"
                   wrapText="true" maxWidth="360" visible="false"/>

            <!-- Username -->
            <VBox spacing="4">
                <Label text="Username" styleClass="field-label"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           styleClass="text-field-styled"/>
            </VBox>

            <Region prefHeight="14"/>

            <!-- Password -->
            <VBox spacing="4">
                <Label text="Password" styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               styleClass="text-field-styled"/>
            </VBox>

            <Region prefHeight="24"/>

            <!-- Login button -->
            <StackPane>
                <Button fx:id="loginButton" text="Sign In"
                        styleClass="btn-primary"
                        maxWidth="Infinity"
                        onAction="#handleLogin"/>
                <ProgressIndicator fx:id="spinner"
                                   prefWidth="24" prefHeight="24"
                                   visible="false"
                                   StackPane.alignment="CENTER_RIGHT">
                    <StackPane.margin><Insets right="12"/></StackPane.margin>
                </ProgressIndicator>
            </StackPane>

            <Region prefHeight="20"/>

            <!-- Register link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?" styleClass="muted-text"/>
                <Button fx:id="registerLink" text="Register here"
                        styleClass="btn-link"
                        onAction="#handleNavigateToRegister"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
